/* components/business/activity-card/activity-card.wxss */
/* 活动卡片组件 */

.l-activity-card {
  background-color: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.l-activity-card__cover {
  position: relative;
  width: 100%;
  padding-top: 56.25%; /* 16:9 比例 */
}

.l-activity-card__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 状态标签 */
.l-activity-card__status {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: var(--font-xs);
  border-radius: var(--radius-sm);
}

/* 内容区域 */
.l-activity-card__content {
  padding: 24rpx;
}

/* 标题 */
.l-activity-card__title {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

/* 信息行 */
.l-activity-card__info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.l-activity-card__info-item {
  display: flex;
  align-items: center;
}

.l-activity-card__icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.l-activity-card__text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部 */
.l-activity-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.l-activity-card__people {
  display: flex;
  align-items: center;
}

.l-activity-card__organizer-text {
  font-size: var(--font-xs);
  color: var(--text-muted);
}
