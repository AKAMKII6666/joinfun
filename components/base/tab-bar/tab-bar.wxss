/* components/base/tab-bar/tab-bar.wxss */
/* 顶部切换 Tab 组件 */

.l-tab-bar {
  background-color: var(--bg-card);
  border-bottom: 1rpx solid var(--border);
}

.l-tab-bar__list {
  display: flex;
  position: relative;
}

.l-tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  position: relative;
}

.l-tab-bar__icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.l-tab-bar__text {
  font-size: var(--font-sm);
  color: var(--text-muted);
  transition: color 0.2s ease;
}

/* 激活状态 */
.l-tab-bar__item--active .l-tab-bar__text {
  color: var(--primary);
  font-weight: 500;
}

/* 底部指示条 */
.l-tab-bar__line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: var(--primary);
  border-radius: 3rpx;
}

/* 禁用状态 */
.l-tab-bar__item--disabled {
  opacity: 0.5;
}
