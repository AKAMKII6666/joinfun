<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 自定义 tabBar -->
  <l-custom-tabbar />

  <!-- 页面内 Tab 切换 -->
  <view class="page-tabs">
    <view 
      class="page-tab {{currentTab === 0 ? 'active' : ''}}" 
      bindtap="onTabChange" 
      data-index="0"
    >
      已报名
    </view>
    <view 
      class="page-tab {{currentTab === 1 ? 'active' : ''}}" 
      bindtap="onTabChange" 
      data-index="1"
    >
      最近浏览
    </view>
  </view>

  <!-- 已报名活动列表 -->
  <view wx:if="{{currentTab === 0}}" class="activity-section">
    <!-- 有数据 -->
    <block wx:if="{{joinedActivities.length > 0}}">
      <view class="activity-list">
        <l-activity-card
          wx:for="{{joinedActivities}}"
          wx:key="id"
          activity="{{item}}"
          bind:click="onActivityClick"
        />
      </view>
    </block>

    <!-- 空状态 -->
    <block wx:else>
      <l-empty-state
        icon="📭"
        title="未报名活动"
        subtitle="快去发布一个活动吧"
        buttonText="免费发布"
        bind:click="onPublishClick"
      />
    </block>
  </view>

  <!-- 最近浏览列表 -->
  <view wx:if="{{currentTab === 1}}" class="activity-section">
    <!-- 有数据 -->
    <block wx:if="{{recentActivities.length > 0}}">
      <view class="activity-list">
        <l-activity-card
          wx:for="{{recentActivities}}"
          wx:key="id"
          activity="{{item}}"
          bind:click="onActivityClick"
        />
      </view>
    </block>

    <!-- 空状态 -->
    <block wx:else>
      <l-empty-state
        icon="👀"
        title="未浏览活动"
        subtitle="浏览的活动会在这里显示"
      />
    </block>
  </view>

  <!-- 发布悬浮按钮 -->
  <l-publish-float-btn bind:click="onPublishClick" />
</view>
