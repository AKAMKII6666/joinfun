/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-page, #F5F5F5);
  padding-bottom: 220rpx;
}

.page-tabs {
  display: flex;
  background-color: #ffffff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.page-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--text-muted);
  position: relative;
}

.page-tab.active {
  color: var(--primary);
  font-weight: 500;
}

.page-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: var(--primary);
  border-radius: 3rpx;
}

.activity-section {
  padding: 24rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
