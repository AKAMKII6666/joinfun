/* components/wechat-login-btn/wechat-login-btn.wxss */

.wechat-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 10rpx 40rpx rgba(12, 193, 96, 0.4);
}

.wechat-btn[disabled] {
  opacity: 0.6;
}

.wechat-btn.loading {
  opacity: 0.8;
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
}
