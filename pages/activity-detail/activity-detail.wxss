/* pages/activity-detail/activity-detail.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

.cover-image {
  width: 100%;
  height: 480rpx;
  border-bottom-left-radius: var(--radius-lg);
  border-bottom-right-radius: var(--radius-lg);
}

.info-section {
  background-color: var(--bg-card);
  padding: 32rpx;
  margin-bottom: 16rpx;
  border-radius: var(--radius-lg);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.share-btn {
  padding: 16rpx;
}

.share-icon {
  font-size: 40rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.info-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.info-action {
  font-size: var(--font-xs);
  color: var(--primary);
}

.desc-section,
.detail-section,
.participants-section,
.guide-section {
  background-color: var(--bg-card);
  padding: 32rpx;
  margin-bottom: 16rpx;
  border-radius: var(--radius-lg);
}

.section-title {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.description {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.detail-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.detail-image-item {
  width: 100%;
  height: 200rpx;
  border-radius: var(--radius-md);
}

.participants-list {
  display: flex;
  align-items: center;
}

.avatar-stack {
  display: flex;
  align-items: center;
}

.avatar-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid var(--bg-card);
}

.view-more {
  margin-left: 32rpx;
  color: var(--primary);
  font-size: var(--font-xs);
}

.view-more {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: var(--font-xs);
}

.guide-images {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.guide-image-item {
  width: 100%;
  height: 240rpx;
  border-radius: var(--radius-md);
}

.bottom-space {
  height: 120rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background-color: var(--bg-card);
  border-top: 1rpx solid var(--border);
}
