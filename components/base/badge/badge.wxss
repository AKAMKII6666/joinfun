/* components/base/badge/badge.wxss */
/* 徽章/角标组件 */

.l-badge-wrapper {
  position: relative;
  display: inline-block;
}

.l-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--error, #FF5252);
  border-radius: 20rpx;
  color: #FFFFFF;
  border: 2rpx solid var(--bg-card);
  z-index: 10;
}

/* 尺寸 */
.l-badge--sm {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
}

.l-badge--md {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
}

.l-badge--lg {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
}

/* 红点模式 */
.l-badge--dot {
  width: 16rpx;
  height: 16rpx;
  min-width: 0;
  padding: 0;
  border-radius: 50%;
  top: -4rpx;
  right: -4rpx;
}

/* 超出最大数量显示 */
.l-badge__text {
  line-height: 1;
  font-weight: 500;
}
