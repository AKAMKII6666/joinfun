/* pages/publish/publish.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.form-item {
  background-color: var(--bg-card);
  padding: 24rpx;
  border-radius: var(--radius-md);
}

.form-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '*';
  color: var(--error);
  margin-right: 8rpx;
}

.image-uploader {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  background-color: var(--bg-page);
  border-radius: var(--radius-md);
  position: relative;
}

.cover-preview {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.add-icon {
  font-size: 64rpx;
  color: var(--text-muted);
}

.add-text {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: var(--error);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.picker-wrap {
  padding: 20rpx 24rpx;
  background-color: var(--bg-page);
  border-radius: var(--radius-md);
  color: var(--text-muted);
}

.picker-wrap.has-value {
  color: var(--text-primary);
}

.time-range {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-separator {
  color: var(--text-muted);
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  height: 160rpx;
}

.image-item .l-image {
  width: 100%;
  height: 100%;
}

.add-btn {
  width: 100%;
  height: 160rpx;
  background-color: var(--bg-page);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: var(--text-muted);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background-color: var(--bg-card);
  border-top: 1rpx solid var(--border);
}
