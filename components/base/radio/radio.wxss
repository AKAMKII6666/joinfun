/* components/base/radio/radio.wxss */
/* 单选框组件 */

.l-radio-wrapper {
  display: block;
}

.l-radio {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.l-radio__circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.l-radio--checked .l-radio__circle {
  border-color: var(--primary);
}

.l-radio__dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: var(--primary);
}

.l-radio__label {
  margin-left: 16rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.l-radio__description {
  width: 100%;
  margin-top: 8rpx;
  margin-left: 56rpx;
  font-size: var(--font-xs);
  color: var(--text-muted);
  line-height: 1.4;
}

/* 禁用状态 */
.l-radio-wrapper--disabled {
  opacity: 0.5;
}

.l-radio-wrapper--disabled .l-radio__label {
  color: var(--text-muted);
}
