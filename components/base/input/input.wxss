/* components/base/input/input.wxss */
/* 基于 TDesign t-input 封装 */

.l-input-wrapper {
  position: relative;
  background-color: var(--bg-card);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border);
  transition: border-color 0.2s ease;
}

.l-input-wrapper--error {
  border-color: var(--error);
}

.l-input-wrapper--disabled {
  background-color: var(--bg-page);
  opacity: 0.6;
}

.l-input {
  height: 80rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.l-input input {
  color: var(--text-primary);
  font-size: var(--font-sm);
}

.l-input__placeholder {
  color: var(--text-muted);
  font-size: var(--font-sm);
}

/* 错误提示 */
.l-input__error-message {
  padding-top: var(--space-xs);
  padding-left: var(--space-sm);
  font-size: var(--font-xs);
  color: var(--error);
  line-height: 1.4;
}

/* 聚焦状态 */
.l-input-wrapper:focus-within {
  border-color: var(--primary);
}

/* 禁用状态 */
.l-input-wrapper--disabled .l-input input {
  color: var(--text-muted);
}
