<!--pages/login/login.wxml-->
<view class="login-container">
  <!-- Logo 区域 -->
  <view class="logo-area">
    <view class="logo">
      <text class="logo-text">快聚会</text>
    </view>
    <text class="subtitle">便捷的组局报名工具</text>
  </view>

  <!-- 登录按钮区域 -->
  <view class="button-area">
    <button 
      class="wechat-btn {{loading ? 'loading' : ''}}" 
      bindtap="onWechatLogin"
      disabled="{{loading}}"
    >
      <image 
        class="wechat-icon" 
        src="data:image/svg+xml;base64," 
        mode="aspectFit"
      />
      <text wx:if="{{!loading}}">微信授权登录</text>
      <text wx:else>登录中...</text>
    </button>
  </view>

  <!-- 底部说明 -->
  <view class="footer">
    <text class="footer-text">登录即表示同意</text>
    <text class="link">《用户协议》</text>
    <text class="footer-text">和</text>
    <text class="link">《隐私政策》</text>
  </view>
</view>
