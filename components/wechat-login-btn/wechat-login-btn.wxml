<!--components/wechat-login-btn/wechat-login-btn.wxml-->
<button 
  class="wechat-btn {{loading ? 'loading' : ''}}" 
  bindtap="onTap"
  disabled="{{loading}}"
>
  <image 
    class="wechat-icon" 
    src="data:image/svg+xml;base64," 
    mode="aspectFit"
  />
  <text wx:if="{{!loading}}">微信授权登录</text>
  <text wx:else>登录中...</text>
</button>
