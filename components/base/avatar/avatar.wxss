/* components/base/avatar/avatar.wxss */
/* 头像组件 */

.l-avatar {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-page);
  overflow: hidden;
  flex-shrink: 0;
}

/* 尺寸 */
.l-avatar--sm {
  width: 64rpx;
  height: 64rpx;
  font-size: 24rpx;
}

.l-avatar--md {
  width: 96rpx;
  height: 96rpx;
  font-size: 32rpx;
}

.l-avatar--lg {
  width: 128rpx;
  height: 128rpx;
  font-size: 40rpx;
}

/* 形状 */
.l-avatar--circle {
  border-radius: 50%;
}

.l-avatar--square {
  border-radius: var(--radius-md);
}

/* 图片 */
.l-avatar__img {
  width: 100%;
  height: 100%;
}

/* 默认头像 */
.l-avatar__default {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background-color: var(--primary-light, #E8F5E9);
  color: var(--primary);
}

.l-avatar__text {
  font-weight: 500;
  text-transform: uppercase;
}

.l-avatar__loading {
  color: var(--text-muted);
}

/* 错误状态 */
.l-avatar--error .l-avatar__img {
  display: none;
}

.l-avatar--error .l-avatar__default {
  background-color: var(--bg-page);
  color: var(--text-muted);
}

/* 角标 */
.l-avatar__badge {
  position: absolute;
  right: -8rpx;
  top: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background-color: var(--error, #FF5252);
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--bg-card);
}
