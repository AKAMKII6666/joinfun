/* components/base/textarea/textarea.wxss */
/* 基于 TDesign t-textarea 封装 */

.l-textarea-wrapper {
  position: relative;
  background-color: var(--bg-card);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border);
  padding: var(--space-sm);
  transition: border-color 0.2s ease;
}

.l-textarea-wrapper--error {
  border-color: var(--error);
}

.l-textarea-wrapper--disabled {
  background-color: var(--bg-page);
  opacity: 0.6;
}

.l-textarea {
  font-size: var(--font-sm);
  color: var(--text-primary);
  min-height: 160rpx;
  line-height: 1.6;
}

.l-textarea textarea {
  color: var(--text-primary);
  font-size: var(--font-sm);
  line-height: 1.6;
}

.l-textarea__placeholder {
  color: var(--text-muted);
  font-size: var(--font-sm);
}

/* 字数统计 */
.l-textarea__counter {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-top: var(--space-xs);
  padding-right: var(--space-xs);
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.l-textarea__counter--over {
  color: var(--error);
}

.l-textarea__counter-total {
  margin-left: 4rpx;
}

/* 错误提示 */
.l-textarea__error-message {
  padding-top: var(--space-xs);
  padding-left: var(--space-sm);
  font-size: var(--font-xs);
  color: var(--error);
  line-height: 1.4;
}

/* 聚焦状态 */
.l-textarea-wrapper:focus-within {
  border-color: var(--primary);
}

/* 禁用状态 */
.l-textarea-wrapper--disabled .l-textarea textarea {
  color: var(--text-muted);
}

/* 自动高度 */
.l-textarea--auto {
  height: auto;
  min-height: 160rpx;
}
